# InvoiceNinja API Configuration
API_URL=https://your-instance.com/api/v1
API_KEY=your_api_token_here

# Optional Settings (defaults shown)
INVOICENINJA_TIMEOUT=30
INVOICENINJA_MAX_RETRIES=3

# Set to 1 to run tests that create/update/delete real data (invoices, expenses, vendors).
# Leave unset to skip write tests - only safe read-only tests will run.
# ALLOW_WRITE_TESTS=1
